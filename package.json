{
  "name": "@slvr-labs/sdk",
  "version": "0.1.2",
  "description": "TypeScript SDK for interacting with the Slvr protocol on Robinhood Chain",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "examples",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "mirror": "bash scripts/publish-mirror.sh"
  },
  "keywords": [
    "slvr",
    "blockchain",
    "ethereum",
    "robinhood",
    "lottery",
    "staking",
    "defi",
    "sdk",
    "typescript"
  ],
  "author": "slvr-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slvr-fun/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/slvr-fun/sdk/issues"
  },
  "homepage": "https://github.com/slvr-fun/sdk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "viem": "^2.40.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9",
    "tsup": "^8.3.5"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": false
    }
  },
  "sideEffects": false
}
